{
  "name": "ai-code-review-security-agent",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack project foundation for AI Code Review & Security Analysis Agent",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "frontend:install": "npm install --workspace=frontend",
    "frontend:dev": "npm run dev --workspace=frontend",
    "frontend:build": "npm run build --workspace=frontend",
    "backend:install": "pip install -r requirements.txt",
    "backend:dev": "uvicorn backend.app.main:app --reload --port 8000",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down"
  }
}
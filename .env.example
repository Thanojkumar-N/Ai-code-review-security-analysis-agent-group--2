# ==========================================
# AI Code Review & Security Agent Configuration
# ==========================================

# System Settings
PROJECT_NAME="AI Code Review & Security Analysis Agent"
VERSION="1.0.0"
ENVIRONMENT=development
DEBUG=true

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1

# Security & Authentication
# Change this to a secure random string in production
JWT_SECRET_KEY=45c08fa5efef4772b22bbcb9ef21516e91cb3cbb42a0b1b1a7d65b79658bd781
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database Settings
# Local development (Docker Compose config uses these defaults)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=ai_code_review_db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres_secure_pass@localhost:5432/ai_code_review_db

# File Storage Configuration
UPLOAD_DIR=uploads
REPORT_DIR=reports
MAX_UPLOAD_SIZE=104857600  # 100MB in bytes
ALLOWED_EXTENSIONS=zip,tar,gz,py,js,ts,tsx,jsx,java,cpp,c,go,rs,html,css
